{
  "entities": {
    "Section": {
      "title": "Main Section",
      "description": "Main sections (e.g., Foodstuff, Meat & Poultry)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category (e.g., Wheat, Rice, Sugar)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "sectionId": { "type": "string" }
      },
      "required": ["name"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Measurement unit (e.g., kg, Liter)",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Package": {
      "title": "Package",
      "description": "Packaging type (e.g., Bag, Box)",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Product brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "A food commodity product with prices",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "unitId": { "type": "string" },
        "packageId": { "type": "string" },
        "brandId": { "type": "string" },
        "agentPrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "retailPrice": { "type": "number" },
        "previousRetailPrice": { "type": "number" },
        "trend": { "type": "string", "enum": ["up", "down", "stable"] },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "origin": { "type": "string" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "categoryId", "agentPrice", "wholesalePrice", "retailPrice"]
    },
    "ExchangeRate": {
      "title": "Exchange Rate",
      "description": "Currency exchange rate",
      "type": "object",
      "properties": {
        "fromCurrency": { "type": "string" },
        "toCurrency": { "type": "string" },
        "rate": { "type": "number" },
        "previousRate": { "type": "number" },
        "trend": { "type": "string", "enum": ["up", "down", "stable"] },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromCurrency", "toCurrency", "rate"]
    },
    "Report": {
      "title": "Report",
      "description": "A user-submitted report about price hikes, fraud, etc.",
      "type": "object",
      "properties": {
        "reporterName": { "type": "string" },
        "reporterPhone": { "type": "string" },
        "reportDate": { "type": "string", "format": "date-time" },
        "reportType": { "type": "string", "enum": ["price_increase", "expired_item", "monopoly", "fraud", "price_diff", "missing_product"] },
        "itemName": { "type": "string" },
        "currentPrice": { "type": "number" },
        "storeName": { "type": "string" },
        "governorate": { "type": "string" },
        "district": { "type": "string" },
        "locationDetails": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "review", "resolved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterName", "reporterPhone", "reportType", "itemName", "governorate", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "User feedback and star rating for products",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating"]
    },
    "AppVisit": {
      "title": "AppVisit",
      "description": "App access log with user governorate",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "governorateId": { "type": "string" },
        "governorateName": { "type": "string" },
        "userAgent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["governorateId", "governorateName"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or admin alert triggered on product additions or price modifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "body", "type"]
    }
  },
  "firestore": {
    "/sections/{sectionId}": { "schema": "Section", "description": "Main sections for grouping categories" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Categories for grouping products" },
    "/units/{unitId}": { "schema": "Unit", "description": "Measurement units" },
    "/packages/{packageId}": { "schema": "Package", "description": "Packaging types" },
    "/brands/{brandId}": { "schema": "Brand", "description": "Product brands" },
    "/products/{productId}": { "schema": "Product", "description": "Individual product data with prices" },
    "/exchangeRates/{rateId}": { "schema": "ExchangeRate", "description": "Currency exchange rates" },
    "/admins/{userId}": { "schema": { "type": "object", "properties": { "role": { "type": "string" } } }, "description": "Admin users" },
    "/reports/{reportId}": { "schema": "Report", "description": "User complaints and reports" },
    "/report_types/{typeId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }, "description": "Configurable report types" },
    "/governorates/{govId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }, "description": "Yemen governorates" },
    "/districts/{distId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "governorateId": { "type": "string" } }, "required": ["name", "governorateId"] }, "description": "Districts within governorates" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "User reviews and ratings for products" },
    "/visits/{visitId}": { "schema": "AppVisit", "description": "App access log with user governorate" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "System or admin alert triggers" }
  }
}
