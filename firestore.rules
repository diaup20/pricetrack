rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isVerifiedAdmin() {
      return isEmailVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'abdsharki20@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Units, Packages, Brands
    match /units/{unitId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Exchange Rates
    match /exchangeRates/{rateId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    // Admins
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isVerifiedAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    function isValidReport(data) {
      return data.reporterName is string && data.reporterName.size() <= 100 &&
             data.reporterPhone is string && data.reporterPhone.size() <= 20 &&
             data.itemName is string && data.itemName.size() <= 200 &&
             data.currentPrice is number &&
             data.governorate is string &&
             data.district is string &&
             data.status in ['new', 'review', 'resolved', 'rejected'] &&
             (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 65536));
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isSignedIn() && 
                      isValidReport(incoming()) && 
                      incoming().userId == request.auth.uid;
      
      allow read: if isVerifiedAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow update, delete: if isVerifiedAdmin();
    }

    match /report_types/{typeId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /governorates/{govId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /districts/{distId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    function isValidReview(data) {
      return data.productId is string && data.productId.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (data.comment == null || (data.comment is string && data.comment.size() <= 1000));
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidReview(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt']);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedAdmin());
    }

    function isValidVisit(data) {
      return data.governorateId is string && data.governorateId.size() <= 64 &&
             data.governorateName is string && data.governorateName.size() <= 100;
    }

    // Visits / App views
    match /visits/{visitId} {
      allow read: if true;
      allow create: if isValidVisit(incoming());
      allow update, delete: if isVerifiedAdmin();
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.body is string && data.body.size() <= 500 &&
             data.type is string && data.type.size() <= 50 &&
             (data.referenceId == null || (data.referenceId is string && data.referenceId.size() <= 128));
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isVerifiedAdmin() && isValidNotification(incoming());
      allow update, delete: if isVerifiedAdmin();
    }
  }
}
